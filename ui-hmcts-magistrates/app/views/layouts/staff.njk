    <ul class="govuk-list" style="display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
      <li><a class="govuk-link" href="/staff/dashboard">Dashboard</a></li>
      <li><a class="govuk-link" href="/staff/candidates">Candidates</a></li>
      <li><a class="govuk-link" href="/staff/vacancies">Vacancies</a></li>
      <li><a class="govuk-link" href="/staff/appeals">Appeals</a></li>
      <li><a class="govuk-link" href="/staff/ryi">RYI</a></li>
      <li><a class="govuk-link" href="/staff/reports">Reports</a></li>
