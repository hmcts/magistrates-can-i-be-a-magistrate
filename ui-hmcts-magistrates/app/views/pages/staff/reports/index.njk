{% extends "layouts/staff.njk" %}

{% block pageTitle %}Reports — {{ serviceName }}{% endblock %}

{% block content %}
  <span class="govuk-caption-l">Staff portal</span>
  <h1 class="govuk-heading-xl">Reports</h1>

  <p class="govuk-body">Total applications: <strong>{{ summary.total }}</strong></p>

  <h2 class="govuk-heading-m govuk-!-margin-top-4">By folder</h2>
  <table class="govuk-table">
    <thead class="govuk-table__head">
      <tr class="govuk-table__row"><th class="govuk-table__header">Folder</th><th class="govuk-table__header">Count</th></tr>
    </thead>
    <tbody class="govuk-table__body">
      {% for f in folders %}
        <tr class="govuk-table__row">
          <td class="govuk-table__cell"><strong class="govuk-tag govuk-tag--{{ f.tagColour }}">{{ f.name }}</strong></td>
          <td class="govuk-table__cell">{{ summary.byFolder[f.key] or 0 }}</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

  <h2 class="govuk-heading-m govuk-!-margin-top-6">By region</h2>
  <table class="govuk-table">
    <thead class="govuk-table__head">
      <tr class="govuk-table__row"><th class="govuk-table__header">Region</th><th class="govuk-table__header">Count</th></tr>
    </thead>
    <tbody class="govuk-table__body">
      {% for region, count in summary.byRegion %}
        <tr class="govuk-table__row"><td class="govuk-table__cell">{{ region }}</td><td class="govuk-table__cell">{{ count }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
{% endblock %}
