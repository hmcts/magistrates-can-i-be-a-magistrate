{% extends "layouts/staff.njk" %}

{% block pageTitle %}{{ candidate.applicantName }} — {{ serviceName }}{% endblock %}

{% block content %}
  <span class="govuk-caption-l">Candidate</span>
  <h1 class="govuk-heading-xl">{{ candidate.applicantName }}</h1>

  {% if error %}
    <div class="govuk-error-summary" data-module="govuk-error-summary">
      <div role="alert"><h2 class="govuk-error-summary__title">There is a problem</h2>
      <div class="govuk-error-summary__body"><p class="govuk-body">{{ error }}</p></div></div>
    </div>
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h2 class="govuk-heading-m">Summary</h2>
      <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Reference</dt>
          <dd class="govuk-summary-list__value">{{ candidate.reference }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Email</dt>
          <dd class="govuk-summary-list__value">{{ candidate.applicantEmail }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Vacancy</dt>
          <dd class="govuk-summary-list__value">{{ candidate.vacancyReference }} — {{ candidate.vacancyTitle }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Region</dt>
          <dd class="govuk-summary-list__value">{{ candidate.region }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Current folder</dt>
          <dd class="govuk-summary-list__value">
            {% if currentFolder %}<strong class="govuk-tag govuk-tag--{{ currentFolder.tagColour }}">{{ currentFolder.name }}</strong>{% endif %}
            <p class="govuk-hint govuk-!-margin-top-1">{{ currentFolder.description }}</p>
          </dd>
        </div>
        {% if candidate.tags.length %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Tags</dt>
            <dd class="govuk-summary-list__value">
              {% for t in candidate.tags %}<strong class="govuk-tag govuk-tag--yellow">{{ t }}</strong> {% endfor %}
            </dd>
          </div>
        {% endif %}
      </dl>

      <h2 class="govuk-heading-m govuk-!-margin-top-6">Stage data</h2>
      {% macro stageRow(label, obj) %}
        {% if obj %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ label }}</dt>
            <dd class="govuk-summary-list__value">
              <ul class="govuk-list govuk-list--bullet">
                {% for k, v in obj %}<li>{{ k }}: {{ v }}</li>{% endfor %}
              </ul>
            </dd>
          </div>
        {% endif %}
      {% endmacro %}
      <dl class="govuk-summary-list">
        {{ stageRow('Eligibility', candidate.eligibility) }}
        {{ stageRow('SJT', candidate.sjt) }}
        {{ stageRow('References', candidate.references) }}
        {{ stageRow('Interview', candidate.interview) }}
        {{ stageRow('DBS', candidate.dbs) }}
        {{ stageRow('Recommendation', candidate.recommendation) }}
        {{ stageRow('JO / SPJ', candidate.jo) }}
        {{ stageRow('Appeal', candidate.appeal) }}
      </dl>

      <h2 class="govuk-heading-m govuk-!-margin-top-6">Folder history</h2>
      <ol class="govuk-list govuk-list--number">
        {% for h in candidate.folderHistory %}
          {% set f = getFolder(h.folder) %}
          <li>
            {% if f %}<strong class="govuk-tag govuk-tag--{{ f.tagColour }}">{{ f.name }}</strong>{% else %}{{ h.folder }}{% endif %}
            — {{ h.enteredAt | date }} by {{ h.by }}{% if h.reason %} ({{ h.reason }}){% endif %}
          </li>
        {% endfor %}
      </ol>

      <h2 class="govuk-heading-m govuk-!-margin-top-6">Comments</h2>
      {% if candidate.comments.length %}
        <ul class="govuk-list">
          {% for c in candidate.comments %}
            <li class="govuk-!-margin-bottom-3">
              <p class="govuk-body govuk-!-margin-bottom-1"><strong>{{ c.by }}</strong> — {{ c.at | date }}</p>
              <p class="govuk-body">{{ c.text }}</p>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body">No comments yet.</p>
      {% endif %}

      <form method="post" action="/staff/candidates/{{ candidate.id }}/comment">
        <div class="govuk-form-group">
          <label class="govuk-label" for="comment-text">Add a comment</label>
          <textarea class="govuk-textarea" id="comment-text" name="text" rows="3"></textarea>
        </div>
        <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">Add comment</button>
      </form>
    </div>

    <div class="govuk-grid-column-one-third">
      <aside>
        <h2 class="govuk-heading-s">Move to next folder</h2>
        {% if nextFolders.length %}
          <form method="post" action="/staff/candidates/{{ candidate.id }}/move">
            <div class="govuk-form-group">
              <label class="govuk-label" for="toFolder">Destination</label>
              <select class="govuk-select" id="toFolder" name="toFolder">
                {% for f in nextFolders %}<option value="{{ f.key }}">{{ f.name }}</option>{% endfor %}
              </select>
            </div>
            <div class="govuk-form-group">
              <label class="govuk-label" for="reason">Reason (optional)</label>
              <input class="govuk-input" id="reason" name="reason" type="text">
            </div>
            <button type="submit" class="govuk-button" data-module="govuk-button">Move</button>
          </form>
        {% else %}
          <p class="govuk-body">No further transitions available.</p>
        {% endif %}

        <h2 class="govuk-heading-s govuk-!-margin-top-6">Stage actions</h2>
        <ul class="govuk-list">
          {% if candidate.currentFolder == 'eligibility_review' %}
            <li>
              <details class="govuk-details" data-module="govuk-details">
                <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Record eligibility outcome</span></summary>
                <form method="post" action="/staff/candidates/{{ candidate.id }}/eligibility" class="govuk-details__text">
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="outcome">Outcome</label>
                    <select class="govuk-select" id="outcome" name="outcome">
                      <option value="pass">Eligible</option>
                      <option value="fail">Not eligible</option>
                    </select>
                  </div>
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="notes">Notes</label>
                    <textarea class="govuk-textarea" id="notes" name="notes" rows="2"></textarea>
                  </div>
                  <button type="submit" class="govuk-button govuk-button--secondary">Save</button>
                </form>
              </details>
            </li>
          {% endif %}
          {% if candidate.currentFolder == 'sjt' %}
            <li>
              <details class="govuk-details" data-module="govuk-details">
                <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Record SJT outcome</span></summary>
                <form method="post" action="/staff/candidates/{{ candidate.id }}/sjt-outcome" class="govuk-details__text">
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="score">Score</label>
                    <input class="govuk-input govuk-input--width-5" id="score" name="score" type="number">
                  </div>
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="outcome-sjt">Outcome</label>
                    <select class="govuk-select" id="outcome-sjt" name="outcome">
                      <option value="pass">Pass</option>
                      <option value="fail">Fail</option>
                    </select>
                  </div>
                  <button type="submit" class="govuk-button govuk-button--secondary">Save</button>
                </form>
              </details>
            </li>
          {% endif %}
          {% if candidate.currentFolder == 'interview' %}
            <li>
              <details class="govuk-details" data-module="govuk-details">
                <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Record interview outcome</span></summary>
                <form method="post" action="/staff/candidates/{{ candidate.id }}/interview-outcome" class="govuk-details__text">
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="score-int">Score</label>
                    <input class="govuk-input govuk-input--width-5" id="score-int" name="score" type="number">
                  </div>
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="outcome-int">Outcome</label>
                    <select class="govuk-select" id="outcome-int" name="outcome">
                      <option value="pass">Pass</option>
                      <option value="fail">Fail</option>
                    </select>
                  </div>
                  <button type="submit" class="govuk-button govuk-button--secondary">Save</button>
                </form>
              </details>
            </li>
          {% endif %}
          {% if candidate.currentFolder == 'recommendation' %}
            <li>
              <details class="govuk-details" data-module="govuk-details">
                <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Record AC Quorum decision</span></summary>
                <form method="post" action="/staff/candidates/{{ candidate.id }}/recommendation" class="govuk-details__text">
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="decision">Decision</label>
                    <select class="govuk-select" id="decision" name="decision">
                      <option value="recommend">Recommend</option>
                      <option value="do_not_recommend">Do not recommend</option>
                    </select>
                  </div>
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="appendix">Appendix info</label>
                    <textarea class="govuk-textarea" id="appendix" name="appendixInfo" rows="2"></textarea>
                  </div>
                  <button type="submit" class="govuk-button govuk-button--secondary">Save</button>
                </form>
              </details>
            </li>
          {% endif %}
          {% if candidate.currentFolder == 'jo_review' %}
            <li>
              <details class="govuk-details" data-module="govuk-details">
                <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Record SPJ decision</span></summary>
                <form method="post" action="/staff/candidates/{{ candidate.id }}/jo-decision" class="govuk-details__text">
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="spjDecision">Decision</label>
                    <select class="govuk-select" id="spjDecision" name="spjDecision">
                      <option value="appoint">Appoint</option>
                      <option value="do_not_appoint">Do not appoint</option>
                    </select>
                  </div>
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="letter">Appointment letter URL</label>
                    <input class="govuk-input" id="letter" name="appointmentLetterUrl" type="text" placeholder="/mock/appointment.pdf">
                  </div>
                  <button type="submit" class="govuk-button govuk-button--secondary">Save</button>
                </form>
              </details>
            </li>
          {% endif %}
          {% if candidate.currentFolder == 'appeal' %}
            <li>
              <details class="govuk-details" data-module="govuk-details">
                <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Record appeal decision</span></summary>
                <form method="post" action="/staff/candidates/{{ candidate.id }}/appeal-decision" class="govuk-details__text">
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="appealOutcome">Outcome</label>
                    <select class="govuk-select" id="appealOutcome" name="outcome">
                      <option value="granted">Granted (appoint)</option>
                      <option value="rejected">Rejected</option>
                    </select>
                  </div>
                  <button type="submit" class="govuk-button govuk-button--secondary">Save</button>
                </form>
              </details>
            </li>
          {% endif %}
        </ul>
      </aside>
    </div>
  </div>
{% endblock %}
