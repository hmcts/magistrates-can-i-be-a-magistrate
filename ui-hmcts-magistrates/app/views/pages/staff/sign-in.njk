{% extends "layouts/main.njk" %}

{% block pageTitle %}Staff sign in — {{ serviceName }}{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                <li><a href="#userId">{{ error }}</a></li>
              </ul>
            </div>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-xl">Staff sign in</h1>

      <div class="govuk-inset-text">
        <strong>Prototype mode:</strong> In production, staff sign in with Azure Entra ID. Select a test user below to sign in as them.
      </div>

      <form method="post" action="/staff/sign-in">
        <input type="hidden" name="returnTo" value="{{ returnTo }}">

        <div class="govuk-form-group">
          <fieldset class="govuk-fieldset">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Select a staff user</legend>
            <div class="govuk-radios" data-module="govuk-radios">
              {% for user in staffUsers %}
                <div class="govuk-radios__item">
                  <input class="govuk-radios__input" id="userId-{{ loop.index }}" name="userId" type="radio" value="{{ user.id }}">
                  <label class="govuk-label govuk-radios__label" for="userId-{{ loop.index }}">
                    {{ user.firstName }} {{ user.lastName }} — {{ user.roleName }}
                  </label>
                  <div class="govuk-hint govuk-radios__hint">{{ user.email }}</div>
                </div>
              {% endfor %}
            </div>
          </fieldset>
        </div>

        <button type="submit" class="govuk-button" data-module="govuk-button">Sign in</button>
      </form>
    </div>
  </div>
{% endblock %}
