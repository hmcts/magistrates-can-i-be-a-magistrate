{% extends "layouts/main.njk" %}

{% block pageTitle %}Interest registered — {{ serviceName }}{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-panel govuk-panel--confirmation">
        <h1 class="govuk-panel__title">Interest registered</h1>
        <div class="govuk-panel__body">Thank you, {{ registrant.firstName }} {{ registrant.lastName }}</div>
      </div>

      <p class="govuk-body">We will contact you at <strong>{{ registrant.email }}</strong> when a magistrate vacancy opens in <strong>{{ registrant.region }}</strong> ({{ registrant.courtType }} court).</p>

      <p class="govuk-body"><a class="govuk-link" href="/">Go to the homepage</a></p>
    </div>
  </div>
{% endblock %}
