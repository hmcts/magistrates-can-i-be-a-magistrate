{% extends "layouts/main.njk" %}

{% set currentPage = "vacancies" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-xl">Find a vacancy</h1>

      <form method="get" action="/vacancies">
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-one-third">
            <div class="govuk-form-group">
              <label class="govuk-label" for="region">Region</label>
              <select class="govuk-select" id="region" name="region">
                <option value="">All regions</option>
                {% if regions %}
                  {% for region in regions %}
                    <option value="{{ region.value }}"{% if region.selected %} selected{% endif %}>{{ region.text }}</option>
                  {% endfor %}
                {% endif %}
              </select>
            </div>
          </div>
          <div class="govuk-grid-column-one-third">
            <div class="govuk-form-group">
              <label class="govuk-label" for="courtType">Court type</label>
              <select class="govuk-select" id="courtType" name="courtType">
                <option value="">All court types</option>
                <option value="criminal">Criminal</option>
                <option value="family">Family</option>
              </select>
            </div>
          </div>
          <div class="govuk-grid-column-one-third govuk-!-padding-top-6">
            <button type="submit" class="govuk-button" data-module="govuk-button">Search</button>
          </div>
        </div>
      </form>

      {% if vacancies and vacancies.length > 0 %}
        <table class="govuk-table">
          <caption class="govuk-table__caption govuk-table__caption--m">Open vacancies</caption>
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Reference</th>
              <th scope="col" class="govuk-table__header">Title</th>
              <th scope="col" class="govuk-table__header">Region</th>
              <th scope="col" class="govuk-table__header">Court type</th>
              <th scope="col" class="govuk-table__header">Closing date</th>
              <th scope="col" class="govuk-table__header"></th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for vacancy in vacancies %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ vacancy.reference }}</td>
                <td class="govuk-table__cell">{{ vacancy.title }}</td>
                <td class="govuk-table__cell">{{ vacancy.region }}</td>
                <td class="govuk-table__cell">{{ vacancy.courtType }}</td>
                <td class="govuk-table__cell">{{ vacancy.closesAt }}</td>
                <td class="govuk-table__cell">
                  <a class="govuk-link" href="/vacancies/{{ vacancy.id }}">View<span class="govuk-visually-hidden"> {{ vacancy.title }}</span></a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% elif searched %}
        <p class="govuk-body">No vacancies found matching your search criteria.</p>
      {% else %}
        <p class="govuk-body">Search for vacancies using the filters above.</p>
      {% endif %}
    </div>
  </div>
{% endblock %}
