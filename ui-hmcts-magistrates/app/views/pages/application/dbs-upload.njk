{% extends "layouts/main.njk" %}

{% block pageTitle %}Upload DBS certificate — {{ serviceName }}{% endblock %}

{% block beforeContent %}
  <a class="govuk-back-link" href="/application/{{ application.id }}/status">Back to application status</a>
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Upload your DBS certificate</h1>

      <p class="govuk-body">Prototype mode — in production this would be a real file upload. Here you enter the filename and we record it.</p>

      <form method="post" action="/application/{{ application.id }}/dbs/upload">
        <div class="govuk-form-group">
          <label class="govuk-label" for="certFilename">Certificate filename</label>
          <input class="govuk-input" id="certFilename" name="certFilename" type="text" placeholder="dbs-certificate.pdf" required>
        </div>
        <button type="submit" class="govuk-button" data-module="govuk-button">Upload</button>
      </form>
    </div>
  </div>
{% endblock %}
